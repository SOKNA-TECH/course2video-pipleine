# ============================================================
# Video-to-Course Pipeline — Configuration Reference
# ============================================================
# Copy these values into the Configuration cell at the top of
# each notebook. You don't need to load this file directly.
# ============================================================

# --- Google Drive Paths ---
# Adjust the Day_X suffix for each day you process
INPUT_VIDEOS_FOLDER=/content/drive/MyDrive/your_videos
OUTPUT_WAVS_FOLDER=/content/drive/MyDrive/your_audio_wavs
OUTPUT_TRANSCRIPTS_FOLDER=/content/drive/MyDrive/your_transcripts
OUTPUT_STRUCTURE_FOLDER=/content/drive/MyDrive/your_structure
OUTPUT_FINAL_CHUNKS_FOLDER=/content/drive/MyDrive/your_final_chunks

# --- Google Cloud Storage (Step 2) ---
# Used as a temporary staging bucket so the ASR API can access audio via public URL.
# No API key needed — Colab handles auth via OAuth popup (auth.authenticate_user()).
# The project ID is only used for bucket creation. The bucket is deleted after transcription.
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-unique-bucket-name
GCS_BUCKET_LOCATION=US

# --- Alibaba Cloud / DashScope ASR (Step 2) ---
# Get a key at: https://www.alibabacloud.com/en/solutions/generative-ai/dashscope
DASHSCOPE_API_KEY=
LANGUAGE=ar

# --- LLM for Semantic Chunking + Articles + Quizzes (Steps 3 & 5) ---
# Default: Kimi K2 via Moonshot. Swap for any OpenAI-compatible provider.
# Used by both 03_semantic_chunking and 05_articles_and_quizzes.
LLM_MODEL_NAME=kimi-k2-thinking
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.ai/v1

# --- S3-Compatible Upload (Step 4, optional) ---
# Supports AWS S3, Railway, Cloudflare R2, MinIO, etc.
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
